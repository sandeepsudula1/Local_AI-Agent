# Local AI Assistant - Configuration Template
#
# Copy this file to .env at the project root and customize for your environment.
# 
# Installation: Place this file at:
#   - Development:  <project_root>/.env
#   - Deployed:     C:\Program Files\Local AI Assistant\.env
#
# After installation, restart the application for changes to take effect.
#
# All values can be overridden via system environment variables (highest priority)
#

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# User identity (used for email draft signatures, reminders, logs)
# Default: Sandeep (current developer)
# Suggestion: Use Windows username or full name
USER_NAME=John Doe


# ═══════════════════════════════════════════════════════════════════════════════
# WINDOWS DOCUMENTS INDEXING
# ═══════════════════════════════════════════════════════════════════════════════

# Primary folder to index for semantic search
# Default: C:\AI_Test_Documents
# Important: Only this folder is indexed by default for security
# Change to: C:\Users\{USERNAME}\Documents\Work  (or any path you want)
WINDOWS_DOCS_PATH=C:\AI_Test_Documents

# Optional: Restrict indexing to specific subfolders
# If empty (default), entire WINDOWS_DOCS_PATH is indexed
# Format: comma-separated folder names relative to WINDOWS_DOCS_PATH
# Examples:
#   WINDOWS_DOCS_SUBFOLDERS=Work,Projects/AI
#   WINDOWS_DOCS_SUBFOLDERS=   (full scan)
WINDOWS_DOCS_SUBFOLDERS=


# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Optional)
# ═══════════════════════════════════════════════════════════════════════════════
# 
# These settings enable compose, send, and search email functionality.
# Leave all blank to disable email features.
#
# For Gmail:
#   Host:     smtp.gmail.com
#   Port:     587
#   Password: Use "App Passwords" (not account password)
#             See: https://support.google.com/accounts/answer/185833
#
# For Outlook:
#   Host:     smtp.live.com
#   Port:     587
#
# For custom SMTP:
#   Contact your email provider for SMTP settings
#

# SMTP server hostname
EMAIL_HOST=smtp.gmail.com

# SMTP server port (typically 587 for TLS, 465 for SSL, 25 for plaintext)
EMAIL_PORT=587

# Your email address (login username)
EMAIL_USER=your-email@gmail.com

# Email password or app-specific password
# WARNING: This is stored in plaintext. File permissions should restrict access.
EMAIL_PASS=your-app-password

# Sender name (display name for sent emails)
EMAIL_FROM=John Doe

# Enable TLS encryption (recommended: true)
EMAIL_TLS=true


# ═══════════════════════════════════════════════════════════════════════════════
# OCR CONFIGURATION (Optional - for PDF/Image Text Extraction)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Tesseract is used as the primary OCR engine for extracting text from:
#   - PDF files (scanned documents)
#   - Images (PNG, JPG, GIF, etc.)
#
# Installation (Windows):
#   1. Download: https://github.com/UB-Mannheim/tesseract/wiki
#   2. Run installer (use default path)
#   3. Verify installation at: C:\Program Files\Tesseract-OCR\tesseract.exe
#
# Leave blank or comment out to skip OCR (faster startup, no scanned PDF support)
#

TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe


# ═══════════════════════════════════════════════════════════════════════════════
# LLM MODEL CONFIGURATION (Advanced)
# ═══════════════════════════════════════════════════════════════════════════════
#
# These settings control which models are used for inference and embeddings.
# Default models are optimized for CPU and low-resource systems.
#
# IMPORTANT: Ollama service must be running locally
#   Download: https://ollama.ai
#   Start: ollama serve
#

# Ollama model name (inference)
# Smaller models (fast, lower resource):
#   - llama3.2:1b    (default, ~1B parameters)
#   - phi:2.7b       (~2.7B parameters)
# Larger models (slower, better quality):
#   - llama3:8b      (~8B parameters)
#   - mistral:7b     (~7B parameters)
MODEL_NAME=llama3.2:1b

# Embedding model (for semantic search)
# This downloads from HuggingFace Hub on first run (~90 MB)
# Options:
#   - sentence-transformers/all-MiniLM-L6-v2      (default, fast)
#   - sentence-transformers/all-mpnet-base-v2     (slower, better quality)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Embedding device: cpu or cuda (GPU)
# Use cuda only if you have NVIDIA GPU with CUDA toolkit installed
EMBEDDING_DEVICE=cpu

# Model temperature (0.0 = deterministic, 1.0 = creative)
MODEL_TEMPERATURE=0.7

# Maximum tokens to generate per response
MODEL_MAX_TOKENS=250

# Vector store retrieval: number of similar documents to return
VECTOR_STORE_K=10

# Retrieval threshold (lower = more lenient matching)
RETRIEVAL_THRESHOLD=1.5


# ═══════════════════════════════════════════════════════════════════════════════
# DOCUMENT PROCESSING (Advanced)
# ═══════════════════════════════════════════════════════════════════════════════

# Chunk size for document splitting (in characters)
# Larger = fewer chunks (faster indexing, coarser search)
# Smaller = more chunks (slower indexing, finer search)
CHUNK_SIZE=1500

# Overlap between chunks (for context preservation)
CHUNK_OVERLAP=150

# Path to documents folder (relative to data directory)
DOCS_PATH=documents


# ═══════════════════════════════════════════════════════════════════════════════
# REMINDER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Reminder poll interval (seconds)
# How often to check if reminders should fire
REMINDER_POLL_INTERVAL=5

# Time window for reminder firing (seconds)
# Reminders fire if current time is within this window of reminder time
REMINDER_FIRE_WINDOW=60


# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL SYNCHRONIZATION (Advanced)
# ═══════════════════════════════════════════════════════════════════════════════

# How many emails to fetch on sync
EMAIL_FETCH_COUNT=200

# Cooldown between email fetches (seconds)
EMAIL_FETCH_COOLDOWN=30

# How often to sync email folder (hours)
EMAIL_SYNC_INTERVAL_HOURS=6

# Semantic search weight for email (0.0-1.0)
# Higher = more weight on semantic similarity
EMAIL_HYBRID_SEMANTIC_WEIGHT=0.7


# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG = very verbose (for troubleshooting)
# INFO = normal (recommended)
# WARNING = only important messages
LOG_LEVEL=INFO

# Log file path (optional)
# If empty, logs only print to console
# If set, logs also written to this file (relative to data directory)
# Example: debug.log  (writes to data/debug.log)
LOG_FILE=

# Log format: text or json
# text = human-readable format
# json = structured JSON (for parsing)
LOG_FORMAT=text


# ═══════════════════════════════════════════════════════════════════════════════
# MCP SERVER CONFIGURATION (Advanced - for editor integration)
# ═══════════════════════════════════════════════════════════════════════════════

# MCP transport: stdio or sse
# stdio = for VS Code / other editors
# sse = for HTTP server mode
MCP_TRANSPORT=stdio

# SSE server port (if MCP_TRANSPORT=sse)
MCP_SSE_PORT=8765


# ═══════════════════════════════════════════════════════════════════════════════
# RETRY & RESILIENCE
# ═══════════════════════════════════════════════════════════════════════════════

# Number of retries for LLM calls (on network/timeout errors)
LLM_RETRY_ATTEMPTS=3

# Delay between retries (seconds)
LLM_RETRY_DELAY=1.0


# ═══════════════════════════════════════════════════════════════════════════════
# ADVANCED: Machine Learning & Performance
# ═══════════════════════════════════════════════════════════════════════════════

# These are usually auto-set by main.py, but can be overridden

# Suppress verbose library output
TRANSFORMERS_VERBOSITY=error

# Disable HuggingFace token implicit loading
HF_HUB_DISABLE_IMPLICIT_TOKEN=1

# Disable parallel tokenization (Windows compatibility)
TOKENIZERS_PARALLELISM=false

# HuggingFace Hub verbosity
HF_HUB_VERBOSITY=error


# ═══════════════════════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. Environment variables have highest priority
#    If set in Windows environment, will override .env values
#
# 2. Paths can use:
#    - Absolute paths: C:\Users\John\Documents
#    - Relative paths: documents  (relative to data directory)
#    - Windows variables: %USERPROFILE%\Documents
#
# 3. After editing .env:
#    - Restart the application for changes to take effect
#    - No editing needed if using environment variables
#
# 4. Secrets Management:
#    - Store EMAIL_PASS in Windows Credential Manager for production
#    - Or use environment variables instead of .env file
#    - Never commit .env with real credentials to git
#
# 5. First-Run Downloads:
#    - First startup may download ~300 MB of models
#    - Requires internet connection
#    - Models cached in ~/.cache/huggingface/
#
# 6. Common Issue: "Ollama unreachable"
#    - Download Ollama: https://ollama.ai
#    - Start daemon: ollama serve
#    - Verify: http://localhost:11434 (should return version)
